{
  "name": "@chirashi/components",
  "version": "0.1.0",
  "private": true,
  "description": "Shared React components for Chirashi blog",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./mdx": {
      "types": "./dist/mdx/index.d.ts",
      "import": "./dist/mdx/index.mjs",
      "require": "./dist/mdx/index.js"
    },
    "./article": {
      "types": "./dist/article/index.d.ts",
      "import": "./dist/article/index.mjs",
      "require": "./dist/article/index.js"
    },
    "./markdown": {
      "types": "./dist/markdown/index.d.ts",
      "import": "./dist/markdown/index.mjs",
      "require": "./dist/markdown/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.mjs",
      "require": "./dist/ui/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "biome format --write src",
    "format:check": "biome format src",
    "check": "biome check src",
    "check:fix": "biome check --write src",
    "storybook": "storybook dev -p 6006 --config-dir .storybook",
    "build-storybook": "storybook build --config-dir .storybook",
    "test-storybook": "test-storybook"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "overrides": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@storybook/addon-a11y": "^10.3.3",
    "@storybook/react": "^9.1.13",
    "@storybook/react-vite": "^9.1.13",
    "@storybook/test-runner": "^0.24.3",
    "@testing-library/dom": "^9.3.4",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/ui": "^4.0.16",
    "jsdom": "^27.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "storybook": "^9.1.13",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.4.21",
    "vitest": "^4.0.16"
  }
}
